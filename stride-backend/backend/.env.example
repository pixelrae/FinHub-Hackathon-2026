# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# ─── Open Payments Credentials ────────────────────────────────────────────────
# Obtain these from https://wallet.interledger-test.dev
# 1. Create an account and two wallet addresses (worker + employer)
# 2. Go to Settings → Developer Keys → Generate key pair
# 3. Copy the Key ID and save the downloaded .key file into this folder

OP_WALLET_ADDRESS=https://ilp.interledger-test.dev/YOUR_HANDLE
OP_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OP_PRIVATE_KEY_PATH=./your_key.key

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./stride.db

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string

# ─── Report signing ───────────────────────────────────────────────────────────
REPORT_SECRET=change-this-to-a-long-random-string
